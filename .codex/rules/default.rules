# PM-Project Codex CLI Rules
# 控制 Codex 可在沙箱外执行的命令

# 允许 git 常规操作
prefix_rule(
    pattern = ["git", ["add", "commit", "status", "diff", "log", "branch", "checkout", "switch", "pull", "fetch", "stash", "tag", "remote"]],
    decision = "allow",
    justification = "常规 git 操作是安全的",
    match = [
        "git add .",
        "git commit -m 'feat: add feature'",
        "git status",
        "git diff HEAD",
        "git log --oneline -10",
        "git branch -a",
        "git checkout feature/test",
        "git switch main",
        "git pull origin main",
        "git fetch --all",
        "git stash",
    ],
    not_match = [
        "git push --force",
        "git reset --hard",
    ],
)

# 需要确认的 git 操作
prefix_rule(
    pattern = ["git", ["push", "merge", "rebase", "reset"]],
    decision = "prompt",
    justification = "推送、合并、变基和重置操作影响远程仓库或可能丢失提交，需要确认",
    match = [
        "git push origin feature/test",
        "git merge main",
        "git rebase main",
        "git reset HEAD~1",
    ],
)

# 禁止强制推送
prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "强制推送会覆盖远程历史，使用 `git push --force-with-lease` 替代",
    match = [
        "git push --force origin main",
    ],
)

# 允许 npm/pnpm 常规操作
prefix_rule(
    pattern = [["npm", "pnpm", "npx"], ["install", "run", "test", "exec", "ci", "ls", "list", "outdated", "audit"]],
    decision = "allow",
    justification = "包管理和测试命令是安全的",
    match = [
        "npm install",
        "npm test",
        "npm run lint",
        "pnpm install",
        "npx playwright test",
    ],
)

# 需要确认的 npm 发布操作
prefix_rule(
    pattern = [["npm", "pnpm"], "publish"],
    decision = "prompt",
    justification = "发布操作会影响公共注册表，需要确认",
)

# 允许常用只读命令
prefix_rule(
    pattern = [["cat", "head", "tail", "wc", "find", "grep", "rg", "fd", "ls", "tree", "echo", "pwd", "which", "type", "file"]],
    decision = "allow",
    justification = "只读文件系统命令是安全的",
)

# 禁止危险的删除操作
prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "禁止递归删除根目录。使用更具体的路径或 `trash` 命令。",
    match = [
        "rm -rf /",
        "rm -rf / --no-preserve-root",
    ],
)

# 需要确认的文件删除
prefix_rule(
    pattern = ["rm"],
    decision = "prompt",
    justification = "文件删除操作不可逆，请确认目标路径",
)

# 允许 Playwright 测试命令
prefix_rule(
    pattern = ["npx", "playwright"],
    decision = "allow",
    justification = "Playwright 测试命令是安全的",
    match = [
        "npx playwright test",
        "npx playwright test --update-snapshots",
        "npx playwright install",
    ],
)
